# External Verification Service — API Keys
# Copy to .env and fill in your keys

# Songkick API (https://www.songkick.com/api_key_requests/new)
SONGKICK_API_KEY=your_songkick_api_key_here

# Bandsintown API (https://artists.bandsintown.com/support/bandsintown-api)
BANDSINTOWN_APP_ID=your_bandsintown_app_id_here

# MusicBrainz and Wikidata require no API key
